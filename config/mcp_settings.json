{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "mcp-tools": {
      "command": "${MCP_SUITE_DIR}/custom/mcp-tools/target/release/mcp-tools"
    },
    "terraform": {
      "command": "${MCP_SUITE_DIR}/custom/terraform/target/release/terraform-mcp"
    }
  }
}
